[
  {
    "name": "auto-validate-on-build",
    "when": "TaskCompleted",
    "condition": {"field": "task_result", "operator": "equals", "value": "success"},
    "action": "suggest_next",
    "model_preference": "cheapest",
    "enabled": true,
    "priority": 10,
    "description": "When a builder task completes successfully, suggest deploying a validator"
  },
  {
    "name": "auto-next-task",
    "when": "SubagentStop",
    "condition": {"field": "hook_event_name", "operator": "equals", "value": "SubagentStop"},
    "action": "suggest_next",
    "model_preference": "best_available",
    "enabled": true,
    "priority": 20,
    "description": "When a subagent finishes, suggest checking for the next unblocked task"
  },
  {
    "name": "auto-notify-complete",
    "when": "TaskCompleted",
    "condition": {"field": "task_result", "operator": "equals", "value": "success"},
    "action": "notify",
    "model_preference": "cheapest",
    "enabled": true,
    "priority": 30,
    "description": "Notify via TTS when a task completes successfully"
  },
  {
    "name": "auto-assessment-refresh",
    "when": "SessionStart",
    "condition": {"field": "source", "operator": "equals", "value": "startup"},
    "action": "log",
    "model_preference": "cheapest",
    "enabled": true,
    "priority": 40,
    "description": "Refresh assessment cache on new session startup"
  },
  {
    "name": "suggest-commit",
    "when": "Stop",
    "condition": {"field": "hook_event_name", "operator": "equals", "value": "Stop"},
    "action": "suggest_next",
    "model_preference": "best_available",
    "enabled": false,
    "priority": 90,
    "description": "Suggest git commit when Claude stops (disabled by default)"
  }
]
