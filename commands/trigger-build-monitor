#!/bin/bash
# Trigger: Build.yml Monitor & Auto-Fix
# Run every 20 minutes to check build.yml, fix failures, deploy to VPS, verify website

set -e

echo "=== Build.yml Monitor & Auto-Fix ==="
echo "Started at: $(date)"

# Configuration
REPO="muah1987/MAHNE"
WORKFLOW="build.yml"
VPS_HOST="51.195.86.239"
VPS_USER="ubuntu"
VPS_PASS="19!Zainul87"
VPS_PATH="/opt/mahne"
CF_TOKEN="_pnmyuFCbQo-9F9qnP4UsdCFtvdib_vgq2KO9llD"
CF_ZONE_ID="17e24c35d3a150b29d07deda8509bfd5"

# Step 1: Check build.yml status
echo "Checking build.yml workflow status..."
LATEST_RUN=$(gh run list --workflow $WORKFLOW --limit 1 --json status,conclusion,databaseId,htmlUrl --jq '.[0]')
RUN_STATUS=$(echo "$LATEST_RUN" | jq -r '.status')
RUN_CONCLUSION=$(echo "$LATEST_RUN" | jq -r '.conclusion')
RUN_ID=$(echo "$LATEST_RUN" | jq -r '.databaseId')

echo "Latest run: #$RUN_ID - Status: $RUN_STATUS, Conclusion: $RUN_CONCLUSION"

# Step 2: If failed, get logs and fix
if [ "$RUN_CONCLUSION" = "failure" ] || [ "$RUN_CONCLUSION" = "cancelled" ]; then
    echo "Run failed! Fetching logs..."
    gh run view $RUN_ID --log > /tmp/build-logs.txt

    echo "Analyzing failure..."
    cat /tmp/build-logs.txt

    # Get the workflow file
    echo "Fetching workflow file for analysis..."
    gh api repos/$REPO/actions/workflows/$WORKFLOW > /tmp/workflow.json

    # Use GitHub MCP to fix the issue
    echo "Attempting auto-fix via GitHub MCP..."
    # This would invoke the GitHub MCP to fix common issues
    # For now, log the failure for manual review
    echo "FAILURE logged. Manual intervention may be required."

    # Re-trigger after potential fix
    echo "Re-triggering workflow..."
    gh workflow run $WORKFLOW
    sleep 30
fi

# Step 3: Wait for success
echo "Waiting for successful build..."
MAX_WAIT=300
WAITED=0
while [ $WAITED -lt $MAX_WAIT ]; do
    CURRENT_STATUS=$(gh run list --workflow $WORKFLOW --limit 1 --json conclusion --jq '.[0].conclusion')
    if [ "$CURRENT_STATUS" = "success" ]; then
        echo "Build succeeded!"
        break
    fi
    echo "Waiting... ($WAITED/$MAX_WAIT)"
    sleep 10
    WAITED=$((WAITED + 10))
done

if [ "$CURRENT_STATUS" != "success" ]; then
    echo "Timeout waiting for build. Exiting."
    exit 1
fi

# Step 4: Deploy to VPS
echo "Deploying to VPS $VPS_HOST..."
sshpass -p "$VPS_PASS" ssh -o StrictHostKeyChecking=no $VPS_USER@$VPS_HOST << 'EOFSSH'
cd /opt/mahne
echo "Checking Docker status..."
docker compose ps
docker compose logs --tail=50

# Check if containers are healthy
HEALTH_STATUS=$(docker compose ps --format json | jq -r '.[0].Health')
if [ "$HEALTH_STATUS" != "healthy" ] && [ "$HEALTH_STATUS" != "" ]; then
    echo "Containers unhealthy, restarting..."
    docker compose down
    docker compose -f docker-compose.prod.yml up -d
    sleep 30
    docker compose ps
fi
EOFSSH

# Step 5: Verify website via Playwright
echo "Verifying website via Playwright..."
playwright screenshot https://mahne.nl /tmp/mahne-screenshot.png 2>/dev/null && echo "Website is UP" || echo "Website may be DOWN"

# Step 6: If website down, check Cloudflare
if ! playwright screenshot https://mahne.nl /tmp/test.png 2>/dev/null; then
    echo "Website appears down. Checking Cloudflare..."
    CF_RESPONSE=$(curl -s "https://api.cloudflare.com/client/v4/zones/$CF_ZONE_ID/dns_records" \
        -H "Authorization: Bearer $CF_TOKEN")
    echo "Cloudflare DNS Status: $CF_RESPONSE"

    # Check tunnel status
    TUNNEL_RESPONSE=$(curl -s "https://api.cloudflare.com/client/v4/cfd_tunnel/$CF_ZONE_ID/tunnels" \
        -H "Authorization: Bearer $CF_TOKEN")
    echo "Tunnel Status: $TUNNEL_RESPONSE"
fi

echo "=== Monitor Complete ==="
echo "Finished at: $(date)"
