          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/task_completed.py --log-only --trigger --cognitive",
