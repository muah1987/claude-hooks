            "timeout": 10,
            "statusMessage": "Loading project vault..."
          },
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/scripts/fetch_profile.py",
            "timeout": 10,
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/scripts/fetch_usage.py fetch",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/session_end.py",
            "timeout": 30
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/permission_request.py --log-only --cognitive",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/post_tool_use_failure.py",
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/subagent_start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Setup": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/setup.py",
            "timeout": 60
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/teammate_idle.py --log-only",
