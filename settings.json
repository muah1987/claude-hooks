  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/pre_tool_use.py --cognitive",
            "timeout": 15,
            "statusMessage": "\u283f Validating tool call..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "\\.(ts|tsx|js|jsx)$",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/validators/ts_eslint_validator.js",
            "timeout": 30,
            "statusMessage": "\u283f ESLint..."
          },
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/validators/ts_tsc_validator.js",
            "timeout": 30,
            "statusMessage": "\u283f TypeScript check..."
          }
        ]
      },
      {
        "matcher": "\\.py$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/post_tool_use.py",
            "timeout": 10,
            "statusMessage": "\u283f Linting Python..."
          }
        ]
      },
      {
        "matcher": "\\.sh$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/validators/shellcheck_validator.py",
            "timeout": 10,
            "statusMessage": "\u283f Shellcheck..."
          }
        ]
      },
      {
        "matcher": "\\.(yml|yaml)$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/validators/yaml_validator.py",
            "timeout": 10,
            "statusMessage": "\u283f YAML lint..."
          }
        ]
      },
      {
        "matcher": "\\.md$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/validators/markdown_validator.py",
            "timeout": 10,
            "statusMessage": "\u283f Markdown lint..."
          }
        ]
      },
      {
        "matcher": "\\.rs$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/validators/rust_validator.py",
            "timeout": 35,
            "statusMessage": "\u283f Cargo check..."
          }
        ]
      },
      {
        "matcher": "\\.go$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/validators/go_validator.py",
            "timeout": 35,
            "statusMessage": "\u283f Go vet..."
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/post_tool_use.py --log-only",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/notification.py --notify",
            "timeout": 15,
            "statusMessage": "\u283f Sending notification..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/stop.py --chat",
            "timeout": 45,
            "statusMessage": "\u283f Saving session..."
          },
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/telegram_notify.py --event stop",
            "timeout": 15,
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/issue_notifier.py",
            "timeout": 30,
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/scripts/memory_tracker.py",
            "timeout": 20,
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/scripts/harness_sync.py",
            "timeout": 30,
            "async": true,
            "statusMessage": "\u283f Syncing harness..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/uv run $HOME/.claude/hooks/subagent_stop.py --notify --trigger --cognitive",
